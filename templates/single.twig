{% extends "base.twig" %}

{% block content %}
	<div class="header-image page-header" style="height: 300px; background-size: cover; background-position: center; background-image: url('{{ post.thumbnail.src }}');">
        
			<div class="container" style="height: 100%">
				<div class="row align-items-end" style="height: 100%">
					<div class="col">
					<h1 class="">{{post.title}}</h1>
					</div>
				
            </div>
        </div>
	</div>

	<article>
		<div class="row">
			<div class="col col-12 col-md-6 col-lg-8">
			<p class="small">
					{{ post.date }}
				</p>
				{{post.content}}
			</div>	
			<div class="col col-12 col-md-6 col-lg-4">
				<h3>Weitere News</h3>
				{{ function('do_shortcode', '[latestnews cols="1" limit="6"]') }}
			</div>
		</div>
	</article>
{% endblock %}
